{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Faerry",
  "version": "0.1.0-alpha.12",
  "identifier": "dev.unejamardiani.faerry",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Faerry",
        "width": 1220,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": true,
    "publisher": "Faerry contributors",
    "homepage": "https://github.com/unejamardiani/faerry",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDQUNCQURBQkJCQ0JENUMKUldSY3ZieTcycnFzVElBdC93NWErSHdGcmllSmRObnl6Q1NmczIxQThVTHJjYWg5WWRaNnJ0ZEEK",
      "endpoints": [
        "https://github.com/unejamardiani/faerry/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
