{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portable agents MCP registry",
  "type": "object",
  "required": ["servers"],
  "properties": {
    "servers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "description": { "type": "string" },
          "type": { "enum": ["remote", "local"] },
          "transport": { "enum": ["http", "stdio"] },
          "url": { "type": "string" },
          "command": { "type": "string" },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "enabled": { "type": "boolean" },
          "headers": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "environment": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "targets": {
            "type": "object",
            "properties": {
              "claudeCode": { "type": "boolean" },
              "codex": { "type": "boolean" },
              "opencode": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
