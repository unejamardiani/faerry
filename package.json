{
  "name": "faerry",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Faerry carries portable agent configuration across tools.",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite --host 127.0.0.1 --port 1420",
    "build": "tauri build",
    "build:frontend": "tsc && vite build",
    "release": "node scripts/release.mjs",
    "package:portable": "node scripts/package-portable.mjs",
    "tauri": "tauri",
    "check": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
